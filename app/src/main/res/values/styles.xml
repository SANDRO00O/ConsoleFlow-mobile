<resources>

    <style name="NavItem">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/background</item>
    </style>

    <style name="NavIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerInParent">true</item>
    </style>

    <style name="SwitchTheme" parent="Theme.AppCompat">
        <item name="colorControlActivated">#FFFFFF</item>
        <item name="colorSwitchThumbNormal">#888888</item>
        <item name="android:colorForeground">#FFFFFF</item>
    </style>

    <!-- Dark styled alert dialog matching app theme -->
    <style name="DarkDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:colorBackground">#111111</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
        <item name="colorAccent">#FFFFFF</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="android:windowBackground">@drawable/dark_dialog_bg</item>
        <item name="android:windowMinWidthMajor">80%</item>
        <item name="android:windowMinWidthMinor">80%</item>
        <item name="buttonBarPositiveButtonStyle">@style/DarkDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DarkDialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/DarkDialogButton</item>
    </style>

    <style name="DarkDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#AAAAAA</item>
    </style>

    <!-- Bottom sheet menu style -->
    <style name="AppBottomSheetDialogTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheet</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="AppBottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="backgroundTint">#111111</item>
        <item name="shapeAppearanceOverlay">@style/AppBottomSheetShape</item>
    </style>

    <style name="AppBottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


    <style name="RoundedThumbnail" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

</resources>
