<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="#000000">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:src="@drawable/arrow_left"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Thin separator -->
    <View android:layout_width="match_parent" android:layout_height="0.5dp"
        android:background="#1F1F1F"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Section: Search -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingBottom="8dp"
                android:text="SEARCH"
                android:textColor="#555555"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"/>

            <!-- Search Engine Row -->
            <LinearLayout
                android:id="@+id/rowSearchEngine"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/menu_item_ripple">

                <ImageView
                    android:id="@+id/settingsEngineIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_engine_google"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search Engine"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/settingsEngineName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Google"
                        android:textColor="#666666"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/arrow_right"
                    android:tint="#444444"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginStart="58dp" android:background="#1A1A1A"/>

            <!-- Browsing Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="BROWSING"
                android:textColor="#555555"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"/>

            <!-- Desktop Mode Toggle -->
            <LinearLayout
                android:id="@+id/rowDesktopMode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/menu_item_ripple">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_menu_desktop"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Desktop Mode"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"/>

                <Switch
                    android:id="@+id/switchDesktop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumb="@null"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginStart="58dp" android:background="#1A1A1A"/>

            <!-- Developer Tools (Eruda) Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="DEVELOPER"
                android:textColor="#555555"
                android:textSize="11sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium"/>

            <!-- Clear Data -->
            <LinearLayout
                android:id="@+id/rowClearData"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/menu_item_ripple">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_menu_clear"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Clear Cache &amp; Data"
                    android:textColor="#FF4444"
                    android:textSize="15sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginStart="58dp" android:background="#1A1A1A"/>

            <!-- App Version -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="32dp"
                android:text="ConsoleFlow v1.0.0"
                android:textColor="#333333"
                android:textSize="12sp"
                android:gravity="center"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
