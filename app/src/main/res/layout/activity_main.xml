<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Search engine favicon icon -->
        <ImageView
            android:id="@+id/imgSearchEngine"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:scaleType="fitCenter"
            android:src="@drawable/tool"
            android:tint="#FFFFFF" />

        <EditText
            android:id="@+id/textUrl"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:hint="Search or type URL"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:paddingHorizontal="16dp"
            android:selectAllOnFocus="true"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555" />

        <ImageView
            android:id="@+id/btnBookmark"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:padding="5dp"
            android:src="@drawable/star_outline"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="2dp"
            android:padding="5dp"
            android:src="@drawable/menu"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:progressDrawable="@drawable/progress_bar"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Web Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintTop_toBottomOf="@id/progressBar">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Fullscreen Video Container -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Find In Page Bar -->
    <LinearLayout
        android:id="@+id/findBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D0D0D"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <EditText
            android:id="@+id/findInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Find in page..."
            android:textColor="#FFF"
            android:textColorHint="#555" />
        <TextView
            android:id="@+id/findMatches"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:layout_marginHorizontal="8dp"
            android:text="0/0" />
        <Button
            android:id="@+id/btnFindPrev"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prev" />
        <Button
            android:id="@+id/btnFindNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next" />
        <ImageView
            android:id="@+id/btnFindClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/close"
            android:tint="#FFFFFF" />
    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/goBack"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@drawable/arrow_left"
            android:tint="#888888"
            android:alpha="0.85" />

        <ImageView
            android:id="@+id/goHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="12dp"
            android:src="@drawable/home"
            android:tint="#FFFFFF" />

        <ImageView
            android:id="@+id/goForward"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@drawable/arrow_right"
            android:tint="#888888"
            android:alpha="0.85" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
