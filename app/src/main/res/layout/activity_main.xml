<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:hardwareAccelerated="true"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:background="@drawable/top_bar_bg"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/webIcon"
            android:layout_width="@dimen/top_bar_height"
            android:layout_height="@dimen/top_bar_height"
            android:background="#01000000"
            android:contentDescription="favicon"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:padding="11dp"
            android:src="@drawable/tool" />

        <EditText
            android:id="@+id/textUrl"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginTop="3dp"
            android:layout_weight="1"
            android:background="#01000000"
            android:hint="@string/input_url"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:maxLines="1"
            android:textColor="@color/input_color"
            android:textColorHint="#2e2e2e"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/btnStart"
            android:layout_width="@dimen/top_bar_height"
            android:layout_height="@dimen/top_bar_height"
            android:layout_marginEnd="2dp"
            android:background="#01000000"
            android:contentDescription="refresh"
            android:padding="11dp"
            android:src="@drawable/refresh" />

    </LinearLayout>

    <!-- WebView area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/progress_color"
            android:progressBackgroundTint="#00000000" />

    </FrameLayout>

    <!-- Bottom nav bar: back | home | forward -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/background"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <RelativeLayout style="@style/NavItem">
            <ImageView
                android:id="@+id/goBack"
                style="@style/NavIcon"
                android:src="@drawable/arrow_left" />
        </RelativeLayout>

        <RelativeLayout style="@style/NavItem">
            <ImageView
                android:id="@+id/goHome"
                style="@style/NavIcon"
                android:src="@drawable/home" />
        </RelativeLayout>

        <RelativeLayout style="@style/NavItem">
            <ImageView
                android:id="@+id/goForward"
                style="@style/NavIcon"
                android:src="@drawable/arrow_right" />
        </RelativeLayout>

    </LinearLayout>

</LinearLayout>
